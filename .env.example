# AutoAgent Configuration
# Copy to .env and adjust as needed

OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1
EMBED_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
CHROMA_COLLECTION=autoagent_knowledge
RETRIEVAL_TOP_K=5

# LangSmith Tracing
#LANGCHAIN_TRACING_V2=true
#LANGCHAIN_API_KEY=
#LANGCHAIN_PROJECT=autoagent
